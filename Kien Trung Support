local speedBox = box("Nhập Speed (max 10000)", UDim2.new(0.05,0,0.28,0))
local jumpBox = box("Nhập Jump (max 10000)", UDim2.new(0.05,0,0.36,0))
local clickBox = box("Click delay (vd: 0.1)", UDim2.new(0.05,0,0.44,0))

