info.TextScaled = true

-- FPS + PING
local last=tick()
local frames=0
RunService.RenderStepped:Connect(function()
	frames+=1
	if tick()-last>=1 then
		local fps=frames
		frames=0
		last=tick()
		local ping=math.floor(player:GetNetworkPing()*1000)
		info.Text="FPS: "..fps.." | Ping: "..ping
	end
end)

-- Rainbow text
task.spawn(function()
	while true do
		for i=0,1,0.01 do
			info.TextColor3=Color3.fromHSV(i,1,1)
			task.wait()
		end
	end
end)

-- AIM
local function getNearest()
	local near,dist=nil,math.huge
	for _,v in pairs(Players:GetPlayers()) do
		if v~=player and v.Team~=player.Team and v.Character and v.Character:FindFirstChild("Head") then
			local d=(player.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
			if d<dist then dist=d near=v end
		end
	end
	return near
end

local function getNextTarget()
	local list={}
	for _,v in pairs(Players:GetPlayers()) do
		if v~=player and v.Team~=player.Team and v.Character and v.Character:FindFirstChild("Head") then
			local d=(player.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
			table.insert(list,{p=v,d=d})
		end
	end
	table.sort(list,function(a,b)return a.d<b.d end)
	for i,v in pairs(list) do
		if v.p==currentTarget then
			return list[i+1] and list[i+1].p or list[1].p
		end
	end
	return list[1] and list[1].p
end

RunService.RenderStepped:Connect(function()
	if AIMBOT and currentTarget then
		local c=currentTarget.Character
		if c and c:FindFirstChild("Head") then
			camera.CFrame = CFrame.new(camera.CFrame.Position, c.Head.Position)
		end
	end
end)

aimBtn.MouseButton1Click:Connect(function()
	AIMBOT=not AIMBOT
	aimBtn.Text="AIMBOT "..(AIMBOT and "ON" or "OFF")
	if AIMBOT then currentTarget=getNearest() end
end)

-- KEY
UIS.InputBegan:Connect(function(i,g)
	if g then return end
	if i.KeyCode==Enum.KeyCode.G then
		currentTarget=getNextTarget()
	end
	if i.KeyCode==CLICK_KEY then
		AUTOCLICK=not AUTOCLICK
	end
end)

-- APPLY INPUT
speedBox.FocusLost:Connect(function()
	local val=tonumber(speedBox.Text)
	if val then
		val=math.clamp(val,16,10000)
		player.Character.Humanoid.WalkSpeed=val
	end
end)

jumpBox.FocusLost:Connect(function()
	local val=tonumber(jumpBox.Text)
	if val then
		val=math.clamp(val,50,10000)
		player.Character.Humanoid.JumpPower=val
	end
end)

local CLICK_DELAY=0.1
clickBox.FocusLost:Connect(function()
	local val=tonumber(clickBox.Text)
	if val then
		CLICK_DELAY=math.clamp(val,0.01,1)
	end
end)

-- AUTOCLICK
task.spawn(function()
	while true do
		if AUTOCLICK then
			mouse1click()
		end
		task.wait(CLICK_DELAY)
	end
end)

