-- FPS + PING
local last = tick()
local frames = 0

RunService.RenderStepped:Connect(function()
	frames += 1
	if tick()-last >=1 then
		local fps = frames
		frames = 0
		last = tick()
		local ping = math.floor(player:GetNetworkPing()*1000)
		info.Text = "FPS: "..fps.." | Ping: "..ping
	end
end)

